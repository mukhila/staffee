# Backend Configuration
# Set BACKEND_URL to your Staffee domain (no trailing slash)
BACKEND_URL=https://your-staffee-domain.com
# API_TOKEN is generated in Admin → Monitoring → Settings & Tokens → Generate
API_TOKEN=your_64_char_agent_token_here

# Monitoring Configuration
SCREENSHOT_INTERVAL=300   # seconds between screenshots (min 60)
IDLE_THRESHOLD=300        # seconds of inactivity before marking idle
SYNC_INTERVAL=60          # seconds between upload flushes

# Screenshot Configuration
BLUR_SCREENSHOTS=false
COMPRESS_QUALITY=80
MAX_SCREENSHOT_SIZE=500000  # 500 KB

# Offline Configuration
OFFLINE_QUEUE_MAX=500

# Consent Configuration
AUTO_CONSENT=false   # set true to skip the consent dialog (enterprise deployments)

# Debug
DEBUG=false
